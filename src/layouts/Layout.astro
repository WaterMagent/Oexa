---
import '../styles/global.css';
import StartupAnimation from '../components/StartupAnimation.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Baumkuchen', description = 'Baumkuchen 的个人博客' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页', icon: '⌂' },
  { href: '/blog', label: '博客', icon: '✎' },
  { href: '/about', label: '关于', icon: '◎' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Baumkuchen</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <StartupAnimation />
    <div class="page-layout">
      <nav class="sidebar">
        <a href="/" class="sidebar-avatar-link">
          <img
            class="sidebar-avatar"
            src="https://avatars.githubusercontent.com/u/195563565?v=4"
            alt="Baumkuchen"
            width="40"
            height="40"
          />
        </a>
        <div class="sidebar-nav">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={{
                'sidebar-item': true,
                active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)),
              }}
              title={item.label}
            >
              <span class="sidebar-icon">{item.icon}</span>
              <span class="sidebar-label">{item.label}</span>
            </a>
          ))}
        </div>
      </nav>
      <main class="main-content">
        <div class="content-area">
          <slot />
        </div>
      </main>
    </div>
    <footer class="footer">
      <p>&copy; {new Date().getFullYear()} Baumkuchen. 保留所有权利。</p>
    </footer>
  </body>
</html>

<style is:global>
  .page-layout {
    display: flex;
    min-height: 100vh;
  }

  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 72px;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 0;
    background: var(--bg-card);
    border-right: 1px solid var(--border);
    z-index: 100;
    gap: 0.5rem;
  }

  .sidebar-avatar-link {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    text-decoration: none !important;
  }

  .sidebar-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .sidebar-avatar:hover {
    border-color: var(--accent);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
    padding: 0 0.5rem;
  }

  .sidebar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 0.6rem 0;
    border-radius: 8px;
    text-decoration: none !important;
    color: var(--text-dim) !important;
    transition: all 0.2s;
    cursor: pointer;
  }

  .sidebar-item:hover {
    background: var(--bg-hover);
    color: var(--text-bright) !important;
  }

  .sidebar-item.active {
    background: var(--bg-hover);
    color: var(--accent) !important;
  }

  .sidebar-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  .sidebar-label {
    font-size: 0.65rem;
    line-height: 1;
  }

  .main-content {
    flex: 1;
    margin-left: 96px;
    min-height: 100vh;
    padding: 0 1.5rem;
  }

  .content-area {
    max-width: 720px;
    margin: 0 auto;
  }

  .footer {
    margin-top: 5rem;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--border);
    margin-left: 96px;
    display: flex;
    justify-content: center;
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  @media (max-width: 600px) {
    .sidebar {
      width: 56px;
    }

    .sidebar-label {
      display: none;
    }

    .main-content {
      margin-left: 72px;
    }

    .footer {
      margin-left: 72px;
    }
  }
</style>
